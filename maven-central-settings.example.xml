<?xml version="1.0" encoding="UTF-8"?>
<!--
  本文件仅为示例模板，可安全提交到 Git。请勿将填写了真实 Token / 密码的版本提交到任何远程仓库。

  用法：将下面 <servers> 整段合并到你本机的 %USERPROFILE%\.m2\settings.xml 的 <settings> 根元素内
  （若已有 <servers>，则把其中的 <server> 条目并入即可）。

  与根 pom.xml 中的 id 对应关系：
  - central  → 快照仓库 + central-publishing-maven-plugin（同一套 Central Portal 用户令牌，见官方文档）
  - ossrh    → 可选；仅在使用传统 Nexus staging 发正式版且账号仍支持时填写
-->
<settings xmlns="http://maven.apache.org/SETTINGS/1.2.0"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://maven.apache.org/SETTINGS/1.2.0 https://maven.apache.org/xsd/settings-1.2.0.xsd">
    <servers>
        <server>
            <id>central</id>
            <!-- Central Portal「生成用户令牌」得到的用户名与密码字段（勿写入仓库） -->
            <username>REPLACE_WITH_PORTAL_TOKEN_USERNAME</username>
            <password>REPLACE_WITH_PORTAL_TOKEN_PASSWORD</password>
        </server>
        <server>
            <id>ossrh</id>
            <!-- 若发正式版仍走 s01 staging 且需要单独凭据时再填；勿提交真实值 -->
            <username>REPLACE_OR_OMIT</username>
            <password>REPLACE_OR_OMIT</password>
        </server>
    </servers>
</settings>
