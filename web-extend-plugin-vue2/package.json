{
  "name": "web-extend-plugin-vue2",
  "version": "0.4.1",
  "publishConfig": {
    "access": "public"
  },
  "description": "Vue 2 host runtime for web-extend-plugin: manifest bootstrap, hostApi, registries, ExtensionPoint",
  "type": "module",
  "main": "./dist/index.cjs",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "default": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "index.d.ts"
  ],
  "peerDependencies": {
    "vue": ">=2.6.14 <3.0.0",
    "vue-router": ">=3.5.0 <4.0.0"
  },
  "dependencies": {
    "semver": "^7.6.3"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-node-resolve": "^15.3.0",
    "@rollup/plugin-typescript": "^12.1.2",
    "@types/node": "^22.10.2",
    "rollup": "^4.28.0",
    "tslib": "^2.8.1",
    "typescript": "^5.7.2",
    "vitest": "^2.1.9",
    "vue": "^2.7.16",
    "vue-router": "^3.6.5"
  },
  "scripts": {
    "build": "rollup -c rollup.config.mjs",
    "test": "vitest run",
    "prepublishOnly": "npm run build && npm run test"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/xtemplus/extend-plugin-framework.git",
    "directory": "web-extend-plugin-vue2"
  },
  "keywords": [
    "vue2",
    "plugin",
    "extension"
  ]
}
