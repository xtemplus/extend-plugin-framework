# 清单与静态资源前缀（经 Vite 代理到 Spring 宿主 / plugin-web-starter）
VITE_FRONTEND_PLUGIN_BASE=/fp-api

# 联调 plugin-example-case/plugins/web/com.example.frontend.demo（默认端口 5188）
VITE_WEB_PLUGIN_DEV_ORIGIN=http://localhost:5188
VITE_WEB_PLUGIN_DEV_IDS=com.example.frontend.demo

# 后端代理目标（宿主清单 API / WebPluginController 所在服务）
VITE_FP_API_PROXY_TARGET=http://localhost:9091
